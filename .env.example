# サイトURL（OGP画像などに使用。本番は https://miyata-station.com など）
NEXT_PUBLIC_SITE_URL=

# Facebook App ID（OGPのfb:app_id用。developers.facebook.comでアプリ作成）
NEXT_PUBLIC_FB_APP_ID=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Web Push（会員向けブラウザ通知）… npx web-push generate-vapid-keys で生成
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Web Push 用の連絡先（mailto: 形式推奨）
VAPID_SUBJECT=mailto:admin@example.com

# Google Form（各種フォームのリンク先）
NEXT_PUBLIC_GOOGLE_FORM_URL=

# Google Sheets（週次フォーム連携用）
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SPREADSHEET_ID=
